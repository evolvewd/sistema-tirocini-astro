---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout title="Conferma accesso - Sistema Tirocini">
  <div class="max-w-md mx-auto mt-12 p-6 bg-white rounded-xl shadow-lg border border-slate-200 text-center">
    <p class="text-slate-600">Verifica in corso...</p>
    <p class="mt-4 text-sm text-slate-500">
      <a href="/" class="text-bordeaux-500 hover:underline">Torna alla home</a>
    </p>
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    (async function () {
      try {
        const { data: { session }, error } = await supabase.auth.getSession();
        if (error) {
          window.location.replace("/auth/login");
          return;
        }
        if (session) {
          window.location.replace("/?signed_in=1");
        } else {
          window.location.replace("/auth/login");
        }
      } catch {
        window.location.replace("/auth/login");
      }
    })();
  </script>
</BaseLayout>
